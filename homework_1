import turtle
import random

# Screen setup
screen = turtle.Screen()
screen.setup(600, 600)
screen.bgcolor("light blue")
screen.title("Fruit Collector Game")

# Player turtle
player = turtle.Turtle()
player.shape("turtle")
player.color("green")
player.penup()
player.speed(0)

# Fruit
fruit = turtle.Turtle()
fruit.shape("circle")
fruit.color("red")
fruit.penup()
fruit.speed(0)

# Score display
score = 0

score_writer = turtle.Turtle()
score_writer.hideturtle()
score_writer.penup()
score_writer.goto(-270, 250)


def update_score():
    score_writer.clear()
    score_writer.write(
        "Score: " + str(score),
        font=("Arial", 18, "bold")
    )


def move_fruit():
    x = random.randint(-260, 260)
    y = random.randint(-230, 230)
    fruit.goto(x, y)


def check_collision():
    global score

    if player.distance(fruit) < 25:
        score += 1
        update_score()
        move_fruit()


def move_up():
    player.sety(player.ycor() + 20)
    check_collision()


def move_down():
    player.sety(player.ycor() - 20)
    check_collision()


def move_left():
    player.setx(player.xcor() - 20)
    check_collision()


def move_right():
    player.setx(player.xcor() + 20)
    check_collision()


# Keyboard controls
screen.listen()
screen.onkeypress(move_up, "w")
screen.onkeypress(move_left, "a")
screen.onkeypress(move_down, "s")
screen.onkeypress(move_right, "d")

update_score()
move_fruit()

screen.mainloop()
